# GitStore Environment Configuration Template
# Copy this file to .env and adjust values as needed

# ============================================================================
# Git Server (Rust)
# ============================================================================
GITSTORE_GIT_PORT=5000
GITSTORE_WS_PORT=8080
GITSTORE_DATA_DIR=/data/repos
GITSTORE_LOG_LEVEL=info
GITSTORE_MAX_FILE_SIZE=52428800  # 50MB
GITSTORE_HOOKS_GIT_RECEIVE_PACK_PRE_RECEIVE_ENABLED=false
GITSTORE_HOOKS_GIT_RECEIVE_PACK_UPDATE_ENABLED=false
GITSTORE_HOOKS_GIT_RECEIVE_PACK_POST_RECEIVE_ENABLED=false
GITSTORE_HOOKS_GIT_RECEIVE_PACK_PROC_RECEIVE_ENABLED=false
GITSTORE_HOOKS_GIT_RECEIVE_PACK_POST_UPDATE_ENABLED=false
GITSTORE_ADMISSION_CONTROL_VALIDATING_ADMISSION_POLICY_PHASE=pre-receive # Applicable only when this hook is enabled

# ============================================================================
# GraphQL API (Go)
# ============================================================================
GITSTORE_API_PORT=4000
GITSTORE_GIT_WS=ws://git-service:8080
GITSTORE_GIT_GRPC=localhost:50051
GITSTORE_CACHE_TTL=300  # 5 minutes
ADMIN_PASSWORD_HASH=change-me-in-production
# GITSTORE_LOG_LEVEL=info (shared with git-server)

# ============================================================================
# Admin UI (Astro/React)
# ============================================================================
GITSTORE_GRAPHQL_URL=http://api:4000/graphql
GITSTORE_SESSION_TIMEOUT=3600  # 1 hour
# GITSTORE_LOG_LEVEL=info (shared with other services)
