# gitstore-git-service configuration
# Copy this file to .env and fill in values as needed.
# Shell environment variables always override values in this file.
# All keys are optional — the service starts without any configuration.

# ── Core ──────────────────────────────────────────────────────────────────────

GITSTORE_HTTP__PORT=9418                    # u16    — HTTP git server listen port
GITSTORE_WS__PORT=8080                      # u16    — WebSocket notification port
GITSTORE_GRPC__PORT=50051                   # u16    — gRPC service port
GITSTORE_GIT__DATA_DIR=/data/repos          # string — path to repository storage
GITSTORE_LOG__LEVEL=info                    # string — trace | debug | info | warn | error
GITSTORE_GIT__REPO__MAX_FILE_SIZE=52428800  # u64    — max upload size in bytes (50 MiB)

# ── Hook phase toggles (all disabled by default) ──────────────────────────────
# These can only be overridden via gitstore.toml [hooks.git_receive_pack] tables.
# Env var overrides for nested keys require the __ (double-underscore) separator.

# GITSTORE_HOOKS__GIT_RECEIVE_PACK__PRE_RECEIVE__ENABLED=false
# GITSTORE_HOOKS__GIT_RECEIVE_PACK__UPDATE__ENABLED=false
# GITSTORE_HOOKS__GIT_RECEIVE_PACK__POST_RECEIVE__ENABLED=false
# GITSTORE_HOOKS__GIT_RECEIVE_PACK__PROC_RECEIVE__ENABLED=false
# GITSTORE_HOOKS__GIT_RECEIVE_PACK__POST_UPDATE__ENABLED=false

# ── Admission control ─────────────────────────────────────────────────────────
# Meaningful only when the pre-receive hook is enabled.

# GITSTORE_ADMISSION_CONTROL__VALIDATING_ADMISSION_POLICY__PHASE=pre-receive
