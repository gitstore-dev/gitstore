# gitstore-git-service configuration
# Copy this file to .env and fill in values as needed.
# Shell environment variables always override values in this file.
# All keys are optional — the service starts without any configuration.

# ── Core ──────────────────────────────────────────────────────────────────────

GITSTORE_HTTP_PORT=9418                   # u16    — HTTP git server listen port
GITSTORE_WS_PORT=8080                     # u16    — WebSocket notification port
GITSTORE_GRPC_PORT=50051                  # u16    — gRPC service port
GITSTORE_DATA_DIR=/data/repos             # string — path to repository storage
GITSTORE_LOG_LEVEL=info                   # string — trace | debug | info | warn | error
GITSTORE_MAX_FILE_SIZE=52428800           # u64    — max upload size in bytes (50 MiB)

# ── Hook phase toggles (all disabled by default) ──────────────────────────────
# These can only be overridden via gitstore.toml [hooks.git_receive_pack] tables.
# Env var overrides for nested keys require the __ (double-underscore) separator.

# GITSTORE_HOOKS_GIT__RECEIVE__PACK_PRE__RECEIVE_ENABLED=false
# GITSTORE_HOOKS_GIT__RECEIVE__PACK_UPDATE__ENABLED=false
# GITSTORE_HOOKS_GIT__RECEIVE__PACK_POST__RECEIVE_ENABLED=false
# GITSTORE_HOOKS_GIT__RECEIVE__PACK_PROC__RECEIVE_ENABLED=false
# GITSTORE_HOOKS_GIT__RECEIVE__PACK_POST__UPDATE_ENABLED=false

# ── Admission control ─────────────────────────────────────────────────────────
# Meaningful only when the pre-receive hook is enabled.

# GITSTORE_ADMISSION__CONTROL_VALIDATING__ADMISSION__POLICY_PHASE=pre-receive
